# Microservices Environment Configuration
# Copy this to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://smartcontract:password@postgres:5432/smartcontract_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Configuration
# The backend reads JWT_SECRET_KEY — set this on Heroku Config Vars
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI API Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com

# Service URLs (for inter-service communication)
API_GATEWAY_URL=http://api-gateway:8000
AUTH_SERVICE_URL=http://auth-service:8001
CONTRACT_SERVICE_URL=http://contract-service:8002
AI_SERVICE_URL=http://ai-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS \u2014 comma-separated frontend origins (set on Heroku Config Vars in production)
# Example production value: https://solivolt.live,https://www.solivolt.live,https://smart-contract-rewriter.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
